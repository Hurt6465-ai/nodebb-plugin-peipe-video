{
  "id": "nodebb-plugin-peipe-video",
  "url": "https://peipe.local/nodebb-plugin-peipe-video",
  "name": "Peipe Video Discover",
  "description": "Official NodeBB-style /video discover page with cached cid 6 feed aggregation.",
  "version": "0.7.0",
  "library": "./library.js",
  "staticDirs": {
    "static": "./static"
  },
  "templates": "templates",
  "languages": "languages",
  "hooks": [
    {
      "hook": "static:app.load",
      "method": "init"
    },
    {
      "hook": "static:api.routes",
      "method": "addRoutes"
    },
    {
      "hook": "action:topic.save",
      "method": "clearCaches"
    },
    {
      "hook": "action:topic.delete",
      "method": "clearCaches"
    },
    {
      "hook": "action:post.save",
      "method": "clearCaches"
    },
    {
      "hook": "action:post.delete",
      "method": "clearCaches"
    },
    {
      "hook": "action:post.vote",
      "method": "clearCaches"
    }
  ],
  "nbbpm": {
    "compatibility": "^4.10.0"
  }
}
